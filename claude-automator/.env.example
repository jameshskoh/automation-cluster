# GCP
# PUBSUB_TOPIC_ID / PUBSUB_SUBSCRIPTION_ID values come from gateway-svc/scripts/provision-pubsub.sh
# output ("Set these when deploying claude-automator").
GCP_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ID=claude-automator-responses
PUBSUB_SUBSCRIPTION_ID=claude-automator-gateway-requests-sub

# File paths
UUID_PATH=./data/uuid.txt
ACK_ID_PATH=./data/ack-id.txt
PID_FILE=./data/claude-automator.pid

# Polling tuning
POLL_INTERVAL_MS=5000
POLL_COUNT=2

# Metrics
OTLP_METRICS_URL=http://your-otlp-collector-ip:4318/v1/metrics
